{
  "name": "image-normalizer",
  "version": "0.1.0",
  "description": "TypeScript library for preprocessing and normalizing images in web applications",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test:run"
  },
  "keywords": [
    "image",
    "normalize",
    "browser",
    "file",
    "blob",
    "heic",
    "compression"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "file-type": "^21.0.0",
    "heic-to": "^1.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "happy-dom": "^17.6.3",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.4"
  }
}
